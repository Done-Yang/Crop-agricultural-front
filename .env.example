# Smart Crop frontend — copy to .env.local and adjust.

# Base URL of the Light Backend read API.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8100

# Must match the backend's API_KEY (in smart_crop_light_backend/.env).
# Leave blank if the backend runs with an empty API_KEY.
NEXT_PUBLIC_API_KEY=scopeAgri@d-k
